# Database
DATABASE_URL="mysql://football:football_password@localhost:3306/football_ai"

# API-Football
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
API_FOOTBALL_KEY=""
# Format: leagueId:season,leagueId:season. Example: 39:2024,140:2024
API_FOOTBALL_LEAGUES="39:2024"
# Optional point-in-time import range. Leave blank to use -7/+10 days around today.
API_FOOTBALL_FIXTURES_FROM=""
API_FOOTBALL_FIXTURES_TO=""
API_FOOTBALL_TIMEZONE="Asia/Ho_Chi_Minh"

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN="http://localhost:3000"
ADMIN_API_TOKEN="change-this-admin-token"

# Worker
WORKER_SCHEDULER_ENABLED=true
FIXTURE_SYNC_CRON="0 */6 * * *"
ODDS_SYNC_CRON="*/15 * * * *"
PREDICTION_SYNC_CRON="5 */1 * * *"
RECOMMENDATION_CRON="*/15 * * * *"
SETTLEMENT_CRON="10 */1 * * *"

# Recommendation rules
RECOMMENDATION_MIN_ODDS=1.40
RECOMMENDATION_MAX_ODDS=4.00
RECOMMENDATION_MIN_EV=0.05
RECOMMENDATION_MIN_EDGE=0.03
RECOMMENDATION_MIN_CONFIDENCE=0.55
RECOMMENDATION_MIN_DATA_QUALITY=0.55
RECOMMENDATION_MAX_ODDS_AGE_MINUTES=180
RECOMMENDATION_MIN_BOOKMAKERS=1
RECOMMENDATION_FIXTURE_HOURS_AHEAD=96
RECOMMENDATION_TOP_PER_FIXTURE=3

# Frontend. INTERNAL_API_URL is used by Next.js server-side rendering.
INTERNAL_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_SITE_NAME="Football Value AI"

# Backtest CLI defaults
BACKTEST_FROM=""
BACKTEST_TO=""
BACKTEST_LEAGUE_ID=""
BACKTEST_FIXTURE_LIMIT=500
BACKTEST_STAKE_UNITS=1
