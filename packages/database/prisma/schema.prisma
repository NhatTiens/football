generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum FixtureStatus {
  UPCOMING
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum RecommendationStatus {
  ACTIVE
  EXPIRED
  REVOKED
  SETTLED
}

enum SettlementResult {
  PENDING
  WIN
  LOSS
  PUSH
  VOID
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum BacktestStatus {
  RUNNING
  SUCCESS
  FAILED
}

model League {
  id           Int           @id @default(autoincrement())
  apiLeagueId  Int
  season       Int
  name         String
  country      String?
  logoUrl      String?       @db.Text
  coverage     Json?
  enabled      Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  fixtures     Fixture[]
  backtestRuns BacktestRun[]

  @@unique([apiLeagueId, season])
  @@index([enabled])
}

model Team {
  id              Int                     @id @default(autoincrement())
  apiTeamId       Int                     @unique
  name            String
  code            String?
  country         String?
  logoUrl         String?                 @db.Text
  venueName       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  homeFixtures    Fixture[]               @relation("HomeTeam")
  awayFixtures    Fixture[]               @relation("AwayTeam")
  lineupSnapshots FixtureLineupSnapshot[]
}

model Fixture {
  id                        Int                        @id @default(autoincrement())
  apiFixtureId              Int                        @unique
  leagueId                  Int
  homeTeamId                Int
  awayTeamId                Int
  kickoffAt                 DateTime
  timezone                  String?
  round                     String?
  venueName                 String?
  referee                   String?
  status                    FixtureStatus              @default(UPCOMING)
  apiStatusShort            String?
  elapsedMinutes            Int?
  homeGoals                 Int?
  awayGoals                 Int?
  halftimeHomeGoals         Int?
  halftimeAwayGoals         Int?
  rawPayload                Json?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  league                    League                     @relation(fields: [leagueId], references: [id])
  homeTeam                  Team                       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam                  Team                       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  oddsSnapshots             OddsSnapshot[]
  oddsCollectionCheckpoints OddsCollectionCheckpoint[]
  externalPrediction        ExternalPrediction?
  recommendations           Recommendation[]
  backtestBets              BacktestBet[]
  lineupSnapshots           FixtureLineupSnapshot[]

  @@index([kickoffAt])
  @@index([leagueId, status, kickoffAt])
  @@index([homeTeamId, kickoffAt])
  @@index([awayTeamId, kickoffAt])
}

model Player {
  id              Int                   @id @default(autoincrement())
  apiPlayerId     Int                   @unique
  name            String
  photoUrl        String?               @db.Text
  defaultPosition String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  lineupEntries   FixtureLineupPlayer[]

  @@index([name])
}

model FixtureLineupSnapshot {
  id              Int                   @id @default(autoincrement())
  fixtureId       Int
  teamId          Int
  formation       String?
  coachApiId      Int?
  coachName       String?
  isConfirmed     Boolean               @default(false)
  starterCount    Int                   @default(0)
  substituteCount Int                   @default(0)
  contentHash     String
  capturedAt      DateTime              @default(now())
  rawPayload      Json?
  fixture         Fixture               @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team            Team                  @relation(fields: [teamId], references: [id])
  players         FixtureLineupPlayer[]

  @@unique([fixtureId, teamId, contentHash])
  @@index([fixtureId, teamId, capturedAt])
  @@index([teamId, capturedAt])
}

model FixtureLineupPlayer {
  id               Int                   @id @default(autoincrement())
  lineupSnapshotId Int
  playerId         Int
  isStarter        Boolean
  shirtNumber      Int?
  position         String?
  grid             String?
  lineupOrder      Int?
  lineupSnapshot   FixtureLineupSnapshot @relation(fields: [lineupSnapshotId], references: [id], onDelete: Cascade)
  player           Player                @relation(fields: [playerId], references: [id])

  @@unique([lineupSnapshotId, playerId])
  @@index([playerId, isStarter])
  @@index([lineupSnapshotId, isStarter])
}

model Bookmaker {
  id              Int              @id @default(autoincrement())
  apiBookmakerId  Int              @unique
  name            String
  enabled         Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  oddsSnapshots   OddsSnapshot[]
  recommendations Recommendation[]
  backtestBets    BacktestBet[]
}

model BettingMarket {
  id            Int            @id @default(autoincrement())
  apiBetId      Int?
  marketCode    String         @unique
  name          String
  marketGroup   String
  lineValue     Float?
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  oddsSnapshots OddsSnapshot[]
}

model OddsSnapshot {
  id              Int              @id @default(autoincrement())
  fixtureId       Int
  bookmakerId     Int
  marketId        Int
  selectionCode   String
  selectionName   String
  lineValue       Float?
  decimalOdds     Float
  isLive          Boolean          @default(false)
  apiUpdatedAt    DateTime?
  capturedAt      DateTime         @default(now())
  rawPayload      Json?
  fixture         Fixture          @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  bookmaker       Bookmaker        @relation(fields: [bookmakerId], references: [id])
  market          BettingMarket    @relation(fields: [marketId], references: [id])
  recommendations Recommendation[]
  backtestBets    BacktestBet[]

  @@index([fixtureId, marketId, capturedAt])
  @@index([fixtureId, bookmakerId, marketId, selectionCode, capturedAt])
}

model OddsCollectionCheckpoint {
  id             Int       @id @default(autoincrement())
  fixtureId      Int
  horizonMinutes Int
  dueAt          DateTime
  status         String    @default("PENDING") @db.VarChar(32)
  attemptedAt    DateTime?
  completedAt    DateTime?
  nextRetryAt    DateTime?
  attempts       Int       @default(0)
  processed      Int       @default(0)
  inserted       Int       @default(0)
  lockToken      String?   @db.VarChar(64)
  errorMessage   String?   @db.Text
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, horizonMinutes])
  @@index([status, dueAt])
  @@index([fixtureId, completedAt])
}

model ExternalPrediction {
  id              Int      @id @default(autoincrement())
  fixtureId       Int      @unique
  homeProbability Float?
  drawProbability Float?
  awayProbability Float?
  advice          String?  @db.Text
  predictedWinner String?
  rawPayload      Json?
  capturedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
  fixture         Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model ExternalPredictionSnapshot {
  id              Int      @id @default(autoincrement())
  fixtureId       Int
  homeProbability Float?
  drawProbability Float?
  awayProbability Float?
  advice          String?  @db.Text
  predictedWinner String?
  rawPayload      Json?
  payloadHash     String   @db.VarChar(64)
  capturedAt      DateTime
  createdAt       DateTime @default(now())

  @@unique([fixtureId, payloadHash])
  @@index([fixtureId, capturedAt])
}

model Recommendation {
  id                    Int                  @id @default(autoincrement())
  fixtureId             Int
  bookmakerId           Int
  oddsSnapshotId        Int
  marketCode            String
  marketName            String
  marketGroup           String
  selectionCode         String
  selectionName         String
  lineValue             Float?
  decimalOdds           Float
  modelProbability      Float
  fairMarketProbability Float
  impliedProbability    Float
  edge                  Float
  expectedValue         Float
  confidenceScore       Float
  dataQualityScore      Float
  recommendationScore   Float
  rankNumber            Int?
  modelVersion          String
  reasons               Json
  status                RecommendationStatus @default(ACTIVE)
  settlementResult      SettlementResult     @default(PENDING)
  simulatedProfitUnits  Float?
  generatedAt           DateTime             @default(now())
  expiresAt             DateTime
  settledAt             DateTime?
  fixture               Fixture              @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  bookmaker             Bookmaker            @relation(fields: [bookmakerId], references: [id])
  oddsSnapshot          OddsSnapshot         @relation(fields: [oddsSnapshotId], references: [id])

  @@index([status, generatedAt])
  @@index([fixtureId, status])
  @@index([marketCode, settlementResult])
}

model SyncRun {
  id           Int        @id @default(autoincrement())
  jobName      String
  status       SyncStatus @default(RUNNING)
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  processed    Int        @default(0)
  inserted     Int        @default(0)
  updated      Int        @default(0)
  errorMessage String?    @db.Text
  metadata     Json?

  @@index([jobName, startedAt])
  @@index([status])
}

model ApiUsage {
  id              Int      @id @default(autoincrement())
  endpoint        String
  requestDate     DateTime @default(now())
  responseStatus  Int
  dailyLimit      Int?
  dailyRemaining  Int?
  minuteLimit     Int?
  minuteRemaining Int?
  durationMs      Int?
  errorMessage    String?  @db.Text

  @@index([requestDate])
  @@index([endpoint, requestDate])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model BacktestRun {
  id                   Int            @id @default(autoincrement())
  name                 String
  leagueId             Int?
  dateFrom             DateTime
  dateTo               DateTime
  fixtureLimit         Int
  stakeUnits           Float          @default(1)
  modelVersion         String
  rules                Json
  status               BacktestStatus @default(RUNNING)
  startedAt            DateTime       @default(now())
  finishedAt           DateTime?
  totalFixtures        Int            @default(0)
  eligibleFixtures     Int            @default(0)
  totalBets            Int            @default(0)
  wins                 Int            @default(0)
  losses               Int            @default(0)
  pushes               Int            @default(0)
  voids                Int            @default(0)
  hitRate              Float?
  profitUnits          Float          @default(0)
  roi                  Float?
  yieldRate            Float?
  averageOdds          Float?
  averageExpectedValue Float?
  maximumDrawdown      Float?
  brierScore           Float?
  errorMessage         String?        @db.Text
  league               League?        @relation(fields: [leagueId], references: [id])
  bets                 BacktestBet[]

  @@index([startedAt])
  @@index([status])
  @@index([leagueId, dateFrom, dateTo])
}

model BacktestBet {
  id                    Int              @id @default(autoincrement())
  runId                 Int
  fixtureId             Int
  bookmakerId           Int
  oddsSnapshotId        Int
  predictedAt           DateTime
  kickoffAt             DateTime
  marketCode            String
  marketName            String
  marketGroup           String
  selectionCode         String
  selectionName         String
  lineValue             Float?
  decimalOdds           Float
  modelProbability      Float
  fairMarketProbability Float
  edge                  Float
  expectedValue         Float
  confidenceScore       Float
  dataQualityScore      Float
  recommendationScore   Float
  rankNumber            Int
  settlementResult      SettlementResult
  stakeUnits            Float
  profitUnits           Float
  homeGoals             Int
  awayGoals             Int
  reasons               Json
  createdAt             DateTime         @default(now())
  run                   BacktestRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  fixture               Fixture          @relation(fields: [fixtureId], references: [id])
  bookmaker             Bookmaker        @relation(fields: [bookmakerId], references: [id])
  oddsSnapshot          OddsSnapshot     @relation(fields: [oddsSnapshotId], references: [id])

  @@index([runId, kickoffAt])
  @@index([marketCode, settlementResult])
  @@index([fixtureId])
}

model FixtureTeamMetric {
  id                  Int      @id @default(autoincrement())
  fixtureId           Int
  teamId              Int
  expectedGoals       Float?
  expectedGoalsSource String?
  shots               Int?
  shotsOnGoal         Int?
  possession          Float?
  corners             Int?
  fouls               Int?
  yellowCards         Int?
  redCards            Int?
  capturedAt          DateTime @default(now())
  rawPayload          Json?

  @@unique([fixtureId, teamId])
  @@index([teamId, fixtureId])
  @@index([capturedAt])
}

model FixtureTeamMetricSnapshot {
  id                  Int      @id @default(autoincrement())
  fixtureId           Int
  teamId              Int
  expectedGoals       Float?
  expectedGoalsSource String?
  shots               Int?
  shotsOnGoal         Int?
  possession          Float?
  corners             Int?
  fouls               Int?
  yellowCards         Int?
  redCards            Int?
  rawPayload          Json?
  payloadHash         String   @db.VarChar(64)
  capturedAt          DateTime
  createdAt           DateTime @default(now())

  @@unique([fixtureId, teamId, payloadHash])
  @@index([fixtureId, teamId, capturedAt])
  @@index([teamId, capturedAt])
}

model HistoricalDataAuditRun {
  id                           Int       @id @default(autoincrement())
  auditVersion                 String    @db.VarChar(160)
  policyVersion                String    @db.VarChar(160)
  status                       String    @db.VarChar(24)
  dateFrom                     DateTime
  dateTo                       DateTime
  replayFixtures               Int
  replayPredictions            Int
  oddsSnapshots                Int
  fixturesWithAnyOdds          Int
  fixturesWithT90Odds          Int
  rawMetricSnapshots           Int
  fundamentalSnapshots         Int
  featureSnapshots             Int
  featureRowsWithLineage       Int
  featureRowsWithMarketLineage Int
  pitViolations                Int       @default(0)
  recommendationStatus         String    @db.VarChar(64)
  summary                      Json
  recommendation               Json
  artifactDirectory            String    @db.VarChar(512)
  payloadHash                  String    @unique @db.VarChar(64)
  startedAt                    DateTime  @default(now())
  finishedAt                   DateTime?
  errorMessage                 String?   @db.Text

  @@index([status, startedAt], map: "HistoricalDataAuditRun_status_started_idx")
  @@index([recommendationStatus, startedAt], map: "HistoricalDataAuditRun_recommendation_started_idx")
}

model HistoricalDataAuditFinding {
  id          Int      @id @default(autoincrement())
  runId       Int
  category    String   @db.VarChar(48)
  severity    String   @db.VarChar(16)
  code        String   @db.VarChar(96)
  message     String   @db.Text
  evidence    Json
  payloadHash String   @db.VarChar(64)
  createdAt   DateTime @default(now())

  @@unique([runId, code, payloadHash], map: "HistoricalDataAuditFinding_run_code_hash_key")
  @@index([runId, severity], map: "HistoricalDataAuditFinding_run_severity_idx")
  @@index([category, severity], map: "HistoricalDataAuditFinding_category_severity_idx")
}

model ProviderReplayRun {
  id                     Int       @id @default(autoincrement())
  providerKey            String    @db.VarChar(96)
  providerMode           String    @db.VarChar(24)
  providerVersion        String    @db.VarChar(160)
  policyVersion          String    @db.VarChar(160)
  status                 String    @db.VarChar(24)
  dateFrom               DateTime
  dateTo                 DateTime
  fixturesPlanned        Int
  fixturesProcessed      Int
  schedulerEvents        Int
  t90EligibleFixtures    Int
  predictions            Int
  settledPredictions     Int
  missingFeatureRows     Int
  missingBaselineRows    Int
  pitViolations          Int       @default(0)
  freshShadowRowsWritten Int       @default(0)
  apiCalled              Boolean   @default(false)
  metrics                Json
  coverage               Json
  configuration          Json
  artifactDirectory      String    @db.VarChar(512)
  payloadHash            String    @unique @db.VarChar(64)
  startedAt              DateTime  @default(now())
  finishedAt             DateTime?
  errorMessage           String?   @db.Text

  @@index([status, startedAt], map: "ProviderReplayRun_status_started_idx")
  @@index([providerKey, startedAt], map: "ProviderReplayRun_provider_started_idx")
}

model ProviderReplayPrediction {
  id                         Int       @id @default(autoincrement())
  runId                      Int
  fixtureId                  Int
  leagueId                   Int
  predictionAsOf             DateTime
  kickoffAt                  DateTime
  resultAvailableAt          DateTime
  horizonMinutes             Int
  marketAvailable            Boolean
  teamMetricSnapshotCount    Int
  oddsSnapshotCount          Int
  latestTeamMetricCapturedAt DateTime?
  latestOddsCapturedAt       DateTime?
  sourceFeaturePayloadHash   String    @db.VarChar(64)
  sourceBaselinePayloadHash  String    @db.VarChar(64)
  baselineHomeProbability    Float
  baselineDrawProbability    Float
  baselineAwayProbability    Float
  candidateHomeProbability   Float
  candidateDrawProbability   Float
  candidateAwayProbability   Float
  actualClass                String    @db.VarChar(12)
  baselineBrier              Float
  candidateBrier             Float
  baselineLogLoss            Float
  candidateLogLoss           Float
  pitSafe                    Boolean
  evidenceClass              String    @db.VarChar(64)
  payloadHash                String    @db.VarChar(64)
  createdAt                  DateTime  @default(now())

  @@unique([runId, fixtureId, payloadHash], map: "ProviderReplayPrediction_run_fixture_hash_key")
  @@index([fixtureId, predictionAsOf], map: "ProviderReplayPrediction_fixture_asof_idx")
  @@index([evidenceClass, createdAt], map: "ProviderReplayPrediction_evidence_created_idx")
}

model ProviderHealthObservation {
  id           Int      @id @default(autoincrement())
  providerKey  String   @db.VarChar(96)
  providerMode String   @db.VarChar(24)
  status       String   @db.VarChar(24)
  capabilities Json
  details      Json
  payloadHash  String   @db.VarChar(64)
  observedAt   DateTime @default(now())

  @@index([providerKey, observedAt], map: "ProviderHealth_provider_observed_idx")
  @@index([status, observedAt], map: "ProviderHealth_status_observed_idx")
}

model ScientificCandidateRegistry {
  id                           Int      @id @default(autoincrement())
  registryKey                  String   @unique @db.VarChar(160)
  experimentId                 String   @db.VarChar(64)
  sourceDiagnosticRunId        Int
  sourceDevelopmentCandidateId Int
  candidateVersion             String   @unique @db.VarChar(180)
  baselineVersion              String   @db.VarChar(160)
  featureContractHash          String   @db.VarChar(64)
  status                       String   @db.VarChar(40)
  horizonMinutes               Int
  marketBranch                 String   @db.VarChar(32)
  method                       String   @db.VarChar(64)
  formulaVersion               String   @db.VarChar(96)
  sources                      Json
  weights                      Json
  temperature                  Float
  maximumProbabilityShift      Float
  minimumFreshFixtures         Int      @default(150)
  minimumFreshBets             Int      @default(30)
  frozenAt                     DateTime @default(now())
  sourcePayload                Json
  payloadHash                  String   @unique @db.VarChar(64)
  createdAt                    DateTime @default(now())

  @@index([status, frozenAt], map: "ScientificCandidateRegistry_status_frozen_idx")
  @@index([horizonMinutes, marketBranch], map: "ScientificCandidateRegistry_route_idx")
}

model ScientificShadowPrediction {
  id                        Int      @id @default(autoincrement())
  registryId                Int
  fixtureId                 Int
  leagueId                  Int
  predictionAsOf            DateTime
  kickoffAt                 DateTime
  labelAvailableAt          DateTime
  horizonMinutes            Int
  marketAvailable           Boolean  @default(false)
  sourceFeatureCreatedAt    DateTime
  sourceBaselineCreatedAt   DateTime
  baselineHomeProbability   Float
  baselineDrawProbability   Float
  baselineAwayProbability   Float
  dixonHomeProbability      Float
  dixonDrawProbability      Float
  dixonAwayProbability      Float
  candidateHomeProbability  Float
  candidateDrawProbability  Float
  candidateAwayProbability  Float
  sourceFeaturePayloadHash  String   @db.VarChar(64)
  sourceBaselinePayloadHash String   @db.VarChar(64)
  freshnessStatus           String   @db.VarChar(40)
  capturedAt                DateTime @default(now())
  sourcePayload             Json
  payloadHash               String   @db.VarChar(64)

  @@unique([registryId, sourceFeaturePayloadHash], map: "ScientificShadowPrediction_registry_feature_key")
  @@unique([registryId, payloadHash], map: "ScientificShadowPrediction_registry_payload_key")
  @@index([registryId, kickoffAt], map: "ScientificShadowPrediction_registry_kickoff_idx")
  @@index([fixtureId, predictionAsOf], map: "ScientificShadowPrediction_fixture_asof_idx")
  @@index([freshnessStatus, capturedAt], map: "ScientificShadowPrediction_freshness_captured_idx")
}

model ScientificShadowEvaluationRun {
  id                  Int       @id @default(autoincrement())
  registryId          Int
  candidateVersion    String    @db.VarChar(180)
  baselineVersion     String    @db.VarChar(160)
  status              String    @db.VarChar(24)
  decisionStatus      String    @db.VarChar(48)
  policyVersion       String    @db.VarChar(96)
  dateFrom            DateTime?
  dateTo              DateTime?
  freshFixtures       Int
  predictionRows      Int
  candidateBets       Int
  leakageViolations   Int       @default(0)
  freshnessViolations Int       @default(0)
  predictionMetrics   Json
  bettingMetrics      Json
  decision            Json
  configuration       Json
  payloadHash         String    @unique @db.VarChar(64)
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  errorMessage        String?   @db.Text

  @@index([registryId, startedAt], map: "ScientificShadowEvaluation_registry_started_idx")
  @@index([decisionStatus, startedAt], map: "ScientificShadowEvaluation_decision_started_idx")
}

model ScientificShadowBet {
  id               Int      @id @default(autoincrement())
  runId            Int
  registryId       Int
  fixtureId        Int
  horizonMinutes   Int
  source           String   @db.VarChar(24)
  predictedAt      DateTime
  kickoffAt        DateTime
  selectionCode    String   @db.VarChar(16)
  decimalOdds      Float
  closingOdds      Float?
  modelProbability Float
  fairProbability  Float?
  edge             Float
  expectedValue    Float
  stakeUnits       Float
  result           String   @db.VarChar(16)
  profitUnits      Float
  clv              Float?
  payloadHash      String   @db.VarChar(64)
  createdAt        DateTime @default(now())

  @@unique([runId, source, fixtureId, payloadHash], map: "ScientificShadowBet_run_source_fixture_hash_key")
  @@index([registryId, kickoffAt], map: "ScientificShadowBet_registry_kickoff_idx")
  @@index([runId, source], map: "ScientificShadowBet_run_source_idx")
}

model ScientificShadowDecision {
  id               Int      @id @default(autoincrement())
  runId            Int      @unique
  registryId       Int
  candidateVersion String   @db.VarChar(180)
  baselineVersion  String   @db.VarChar(160)
  status           String   @db.VarChar(48)
  passed           Boolean
  gates            Json
  reasons          Json
  deltas           Json
  freshFixtures    Int
  candidateBets    Int
  payloadHash      String   @unique @db.VarChar(64)
  createdAt        DateTime @default(now())

  @@index([registryId, createdAt], map: "ScientificShadowDecision_registry_created_idx")
  @@index([status, createdAt], map: "ScientificShadowDecision_status_created_idx")
}

model ScientificDiagnosticRun {
  id                        Int       @id @default(autoincrement())
  sourceEvaluationRunId     Int
  diagnosticVersion         String    @db.VarChar(160)
  developmentPolicyVersion  String    @db.VarChar(160)
  status                    String    @db.VarChar(24)
  sourceCandidateVersion    String    @db.VarChar(160)
  baselineVersion           String    @db.VarChar(160)
  featureContractHash       String    @db.VarChar(64)
  artifactDirectory         String    @db.VarChar(512)
  artifactSha256            Json
  rows                      Int
  fixtures                  Int
  developmentRows           Int
  evaluationRows            Int
  leakageViolations         Int       @default(0)
  developmentCandidateCount Int       @default(0)
  diagnosticSummary         Json
  configuration             Json
  startedAt                 DateTime  @default(now())
  finishedAt                DateTime?
  errorMessage              String?   @db.Text

  @@index([status, startedAt], map: "ScientificDiagnostic_status_started_idx")
  @@index([sourceEvaluationRunId, startedAt], map: "ScientificDiagnostic_source_run_idx")
  @@index([diagnosticVersion, startedAt], map: "ScientificDiagnostic_version_started_idx")
}

model ScientificDevelopmentCandidate {
  id                        Int      @id @default(autoincrement())
  diagnosticRunId           Int
  horizonMinutes            Int
  marketBranch              String   @db.VarChar(32)
  status                    String   @db.VarChar(48)
  method                    String   @db.VarChar(64)
  experimentId              String?  @db.VarChar(64)
  sources                   Json
  weights                   Json
  temperature               Float?
  maximumProbabilityShift   Float?
  fitFixtures               Int      @default(0)
  calibrationFixtures       Int      @default(0)
  validationFixtures        Int      @default(0)
  fitMetrics                Json
  calibrationMetrics        Json
  validationMetrics         Json
  baselineValidationMetrics Json
  gates                     Json
  deltas                    Json
  evaluationHoldoutUsed     Boolean  @default(false)
  payloadHash               String   @db.VarChar(64)
  createdAt                 DateTime @default(now())

  @@unique([diagnosticRunId, horizonMinutes, marketBranch, payloadHash], map: "ScientificDevelopmentCandidate_run_horizon_branch_hash_key")
  @@index([status, createdAt], map: "ScientificDevelopmentCandidate_status_created_idx")
